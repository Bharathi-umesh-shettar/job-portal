<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Job Application Form</title>

<style>
body {
  font-family: Arial, sans-serif;
  background: #f4f4f4;
  margin: 0;
  padding: 0;
}

.header {
  background: #e58f39;
  color: white;
  text-align: center;
  padding: 20px;
  font-size: 36px;
  font-weight: bold;
}

.container {
  width: 85%;
  margin: auto;
  background: white;
  padding: 30px;
  margin-top: 30px;
  border-radius: 8px;
  box-shadow: 0 0 10px rgba(0,0,0,0.1);
}

.section {
  margin-bottom: 30px;
}

.section h2 {
  background: #f1f1f1;
  padding: 10px;
  border-radius: 5px;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 20px;
  margin-top: 15px;
}

input, textarea {
  width: 100%;
  padding: 10px;
  border: 1px solid #ccc;
  border-radius: 4px;
}

textarea {
  height: 80px;
}

label {
  font-weight: bold;
}

button {
  margin-top: 20px;
  padding: 12px 20px;
  background: #e58f39;
  border: none;
  color: white;
  font-size: 16px;
  border-radius: 5px;
  cursor: pointer;
}

button:hover {
  background: #cf7424;
}

small {
  display: block;
  margin-top: 5px;
  color: #555;
}
</style>
</head>

<body>

<div class="header">
  Job Application Form
</div>

<div class="container">

  <!-- ===== FORM START ===== -->
  <form action="/apply-job/<%= job._id %>" method="POST" enctype="multipart/form-data">
    
    <!-- PERSONAL DETAILS -->
    <div class="section">
      <h2>Personal Details</h2>
      <div class="grid">
        <div>
          <label>Full Name</label>
          <input type="text" name="name" value="<%= user ? user.name : '' %>" required>
        </div>
        <div>
          <label>Email</label>
          <input type="email" name="email" value="<%= user ? user.email : '' %>" required>
        </div>
        <div>
          <label>Phone</label>
          <input type="text" name="phone" value="<%= user ? user.phone || '' : '' %>" required>
        </div>
      </div>
    </div>

    <!-- COVER LETTER -->
    <div class="section">
      <h2>Cover Letter</h2>
      <textarea name="coverLetter" placeholder="Write your cover letter here..."></textarea>
    </div>

    <!-- UPLOAD RESUME -->
    <div class="section">
      <h2>Upload Resume</h2>
      <input type="file" name="resume" accept=".pdf,.doc,.docx" required>
      <small>Allowed formats: PDF, DOC, DOCX. Max size: 5MB.</small>
    </div>

    <center>
      <button type="submit">Submit Application</button>
    </center>

  </form>
  <!-- ===== FORM END ===== -->

</div>

</body>
</html>