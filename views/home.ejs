<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Job Portal</title>

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family: Arial, sans-serif;
}

/* NAVBAR */
nav{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:20px 60px;
  background:#222;
  color:white;
}

nav ul{
  display:flex;
  list-style:none;
}

nav ul li{
  margin-left:25px;
}

nav ul li a{
  text-decoration:none;
  color:white;
  font-weight:bold;
  transition: color 0.3s;
}

nav ul li a:hover{
  color:#ff4d4d;
}

/* HERO */
.hero{
  height:80vh;
  background:url("https://images.unsplash.com/photo-1486312338219-ce68d2c6f44d") center/cover no-repeat;
  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:center;
  color:white;
  text-align:center;
  padding:0 20px;
}

.hero h1{
  font-size:55px;
  margin-bottom:20px;
}

.hero h1 span{
  color:#ff4d4d;
}

/* SEARCH BOX */
.search-box{
  margin-top:20px;
}

.search-box input{
  padding:12px;
  width:250px;
  border:none;
  border-radius:4px;
}

.search-box button{
  padding:12px 20px;
  background:#ff4d4d;
  border:none;
  color:white;
  cursor:pointer;
  border-radius:4px;
  transition: background 0.3s;
}

.search-box button:hover{
  background:#e03e3e;
}

/* CATEGORIES */
.categories{
  padding:50px 20px;
  text-align:center;
}

.category-container{
  display:flex;
  justify-content:center;
  flex-wrap:wrap;
  gap:30px;
  margin-top:30px;
}

.category{
  background:#f2f2f2;
  padding:20px;
  width:150px;
  border-radius:8px;
  transition: transform 0.3s, box-shadow 0.3s;
}

.category:hover{
  transform: translateY(-5px);
  box-shadow: 0 8px 15px rgba(0,0,0,0.1);
}
</style>

</head>
<body>

<!-- NAVBAR -->
<nav>
  <h2>JOB PORTAL</h2>
  <ul>
    <li><a href="/">Home</a></li>
    <li><a href="/login">Job Seeker Login</a></li>
    <li><a href="/register">Register</a></li>
    <li><a href="/login">Employer Login</a></li>
  </ul>
</nav>

<!-- HERO SECTION -->
<section class="hero">
  <h1>Find The Perfect <span>Job</span></h1>
  <p>Search thousands of jobs from top companies</p>

  <div class="search-box">
    <form action="/dashboard" method="GET">
      <input type="text" name="search" placeholder="Search jobs..." required>
      <button type="submit">Search</button>
    </form>
  </div>
</section>

<!-- JOB CATEGORIES -->
<section class="categories">
  <h2>Popular Job Categories</h2>
  <div class="category-container">
    <div class="category">
      <h3>IT</h3>
      <p>120 Jobs</p>
    </div>
    <div class="category">
      <h3>Marketing</h3>
      <p>80 Jobs</p>
    </div>
    <div class="category">
      <h3>HR</h3>
      <p>45 Jobs</p>
    </div>
    <div class="category">
      <h3>Finance</h3>
      <p>60 Jobs</p>
    </div>
  </div>
</section>

</body>
</html>